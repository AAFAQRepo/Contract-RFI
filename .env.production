# ── PostgreSQL ──
POSTGRES_DB=contract_rfi
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
# Use 'postgres' (service name) instead of 'localhost'
DATABASE_URL=postgresql+asyncpg://admin:changeme@postgres:5432/contract_rfi
DATABASE_URL_SYNC=postgresql://admin:changeme@postgres:5432/contract_rfi

# ── Redis ──
# Use 'redis' (service name) instead of 'localhost'
REDIS_URL=redis://redis:6379/0

# ── Qdrant ──
# Use 'qdrant' (service name) instead of 'localhost'
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ── MinIO ──
# Use 'minio' (service name) instead of 'localhost'
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=contracts
MINIO_SECURE=false

# ── GPU Offloading ──
USE_GPU_SERVER=true
GPU_SERVER_IP=backend

# ── LLM (SGLang) ──
SGLANG_LLM_PROVIDER=sglang
SGLANG_API_KEY=your-production-key
SGLANG_BASE_URL=https://locallm.aafaq.ai/v1
SGLANG_INTENT_MODEL=meta-llama/Llama-3.1-8B-Instruct
SGLANG_USE_FORM_DATA=false

# ── Embedding ──
EMBEDDING_MODEL=intfloat/multilingual-e5-large-instruct

# ── Reranker ──
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ── Celery ──
# Use 'redis' (service name)
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── App ──
APP_ENV=production
APP_SECRET_KEY=generate-a-secure-key-for-production
